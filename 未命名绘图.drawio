        <mxCell id="ajTq3vIyQaHJYTn10AUo-83" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=15;fontStyle=1;fontColor=#d11a1a;" value="忙碌/完成状态" vertex="1" />
        <mxCell id="ajTq3vIyQaHJYTn10AUo-84" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;dashed=1;dashPattern=8 8;fontSize=16;arcSize=8;" value="&lt;b&gt;核心要点说明&lt;/b&gt;&lt;br&gt;&lt;br&gt;① 分支比较在EX阶段完成，而不是ID阶段。&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;② 执行级前存在MEM/WB前递，提供操作数旁路。&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;③ 乘法器和除法器是多周期执行单元。&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;④ 多周期执行时会暂停流水推进。&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;⑤ EX阶段同时承担结果生成、访存地址生成、控制流重定向和分支预测反馈。" vertex="1" />
