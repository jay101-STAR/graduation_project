        <mxCell id="-Y6Ck9xvyRiHn1pDt7g0-102" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffdf4;strokeColor=#d89b1d;strokeWidth=1.5;fontSize=14;align=center;verticalAlign=middle;" value="导向信号管理与优先级控制" vertex="1">
